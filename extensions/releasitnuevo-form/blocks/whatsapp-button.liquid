{{ 'whatsapp-button.css' | asset_url | stylesheet_tag }}

{% liquid
  assign page_type = request.page_type

  assign phone_clean = block.settings.phone_number | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.'

  if page_type == 'product'
    assign product_url = product.url | prepend: shop.url
    assign raw_msg = block.settings.message_product | replace: '[product_name]', product.title | replace: '[product_url]', product_url
  elsif page_type == 'index'
    assign raw_msg = block.settings.message_home
  elsif page_type == 'collection'
    assign raw_msg = block.settings.message_collection | replace: '[collection_name]', collection.title
  else
    assign raw_msg = block.settings.message_default
  endif

  if raw_msg == blank
    assign raw_msg = block.settings.message_default
  endif

  assign encoded_msg = raw_msg | url_encode
  assign wa_url_web = 'https://wa.me/' | append: phone_clean | append: '?text=' | append: encoded_msg
  assign wa_url_scheme = 'whatsapp://send?phone=' | append: phone_clean | append: '&text=' | append: encoded_msg

  assign position_class = 'wa-pos-bottom-right'
  if block.settings.button_position == 'bottom_left'
    assign position_class = 'wa-pos-bottom-left'
  endif

  assign visibility_class = ''
  unless block.settings.show_on_mobile
    assign visibility_class = visibility_class | append: ' wa-hide-mobile'
  endunless
  unless block.settings.show_on_desktop
    assign visibility_class = visibility_class | append: ' wa-hide-desktop'
  endunless

  assign pulse_class = ''
  if block.settings.pulse_animation
    assign pulse_class = ' wa-pulse'
  endif
%}

{%- if phone_clean != blank -%}
  <div
    id="releasit-wa-btn"
    class="wa-btn-container {{ position_class }}{{ visibility_class }}{{ pulse_class }}"
    style="--wa-size: {{ block.settings.button_size }}px; --wa-margin-x: {{ block.settings.button_margin }}px; --wa-margin-y: {{ block.settings.button_margin_y }}px; --wa-color: {{ block.settings.button_color }}; --wa-tooltip-bg: {{ block.settings.tooltip_bg_color }}; --wa-tooltip-color: {{ block.settings.tooltip_text_color }};"
    data-wa-scheme="{{ wa_url_scheme }}"
    data-page-type="{{ page_type }}"
    {% if page_type == 'product' %}
      data-product-id="{{ product.id }}"
      data-product-name="{{ product.title | escape }}"
      data-product-price="{{ product.price | money_without_currency | strip_html }}"
    {% endif %}
    {% if page_type == 'collection' %}
      data-collection-name="{{ collection.title | escape }}"
    {% endif %}
  >
    {% if block.settings.tooltip_text != blank %}
      <span class="wa-tooltip">{{ block.settings.tooltip_text }}</span>
    {% endif %}

    <a
      class="wa-btn"
      href="{{ wa_url_web }}"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
    >
      <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M16.004 0C7.165 0 .004 7.161.004 15.999c0 2.819.734 5.574 2.13 7.998L.014 32l8.208-2.078A15.94 15.94 0 0 0 16.004 32C24.838 32 32 24.837 32 15.999 32 7.161 24.838 0 16.004 0zm0 29.392a13.36 13.36 0 0 1-7.226-2.116l-.518-.308-5.372 1.36 1.392-5.198-.338-.537A13.32 13.32 0 0 1 2.612 16C2.612 8.6 8.604 2.608 16.004 2.608S29.392 8.6 29.392 16c0 7.398-5.99 13.392-13.388 13.392zm7.342-10.024c-.402-.202-2.381-1.175-2.75-1.31-.37-.133-.64-.2-.908.202-.268.4-1.042 1.31-1.278 1.578-.236.268-.47.302-.872.1-.402-.2-1.698-.625-3.234-1.994-1.195-1.066-2.002-2.382-2.236-2.784-.236-.4-.026-.618.176-.818.182-.18.402-.47.604-.706.2-.236.268-.4.402-.668.134-.268.068-.502-.034-.702-.1-.202-.908-2.188-1.244-2.994-.328-.786-.66-.68-.908-.692l-.774-.014c-.268 0-.704.1-1.072.502-.37.4-1.41 1.376-1.41 3.358 0 1.982 1.444 3.896 1.646 4.164.2.268 2.84 4.334 6.882 6.078.962.414 1.712.662 2.298.848.964.308 1.842.264 2.536.16.774-.116 2.382-.974 2.718-1.914.334-.94.334-1.748.234-1.914-.1-.17-.368-.268-.77-.47z"/>
      </svg>
    </a>
  </div>

  <script>
    (function () {
      var el = document.getElementById('releasit-wa-btn');
      if (!el) return;
      var link = el.querySelector('a.wa-btn');
      if (!link) return;

      var isMobile = /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);
      if (isMobile) {
        var scheme = el.getAttribute('data-wa-scheme');
        if (scheme) {
          link.setAttribute('href', scheme);
          link.removeAttribute('target');
          link.removeAttribute('rel');
        }
      }

      function genEventId() {
        try {
          if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
        } catch (e) {}
        return 'wa_' + Date.now() + '_' + Math.random().toString(36).slice(2, 10);
      }

      link.addEventListener('click', function () {
        var pageType = el.getAttribute('data-page-type') || '';
        var productId = el.getAttribute('data-product-id') || '';
        var productName = el.getAttribute('data-product-name') || '';
        var productPrice = el.getAttribute('data-product-price') || '';
        var collectionName = el.getAttribute('data-collection-name') || '';
        var eventId = genEventId();

        var payload = {
          content_name: productName || collectionName || document.title,
          content_category: pageType,
          page_url: window.location.href,
          channel: 'whatsapp'
        };
        if (productId) payload.content_ids = [String(productId)];

        try {
          if (typeof fbq !== 'undefined') {
            fbq('track', 'Lead', payload, { eventID: eventId });
            fbq('trackCustom', 'WhatsAppClick', payload, { eventID: eventId });
          }
        } catch (e) {}

        // Backend tracking (non-blocking — sendBeacon survives navigation)
        try {
          var trackPayload = JSON.stringify({
            eventId: eventId,
            sessionId: (function () {
              try {
                var k = 'rn_wa_sid';
                var sid = localStorage.getItem(k);
                if (!sid) {
                  sid = 'wa_' + Date.now() + '_' + Math.random().toString(36).slice(2, 10);
                  localStorage.setItem(k, sid);
                }
                return sid;
              } catch (e) { return null; }
            })(),
            pageType: pageType,
            pageUrl: window.location.href,
            productId: productId || null,
            productName: productName || null,
            productPrice: productPrice || null,
            collectionName: collectionName || null,
            referrer: document.referrer || null,
            userAgent: navigator.userAgent
          });
          var trackUrl = '/apps/releasitnuevo/wa-click';
          if (navigator.sendBeacon) {
            navigator.sendBeacon(trackUrl, new Blob([trackPayload], { type: 'application/json' }));
          } else {
            fetch(trackUrl, { method: 'POST', keepalive: true, headers: { 'Content-Type': 'application/json' }, body: trackPayload });
          }
        } catch (e) {}

        try {
          if (typeof gtag !== 'undefined') {
            gtag('event', 'whatsapp_click', {
              page_type: pageType,
              product_name: productName,
              value: payload.value || undefined
            });
          }
          if (window.dataLayer) {
            window.dataLayer.push({
              event: 'whatsapp_click',
              page_type: pageType,
              product_name: productName,
              product_id: productId
            });
          }
        } catch (e) {}
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Botón de WhatsApp",
  "target": "body",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "text",
      "id": "phone_number",
      "label": "t:whatsapp_button.settings.phone_number.label",
      "default": "573105879824",
      "placeholder": "573001234567"
    },
    {
      "type": "header",
      "content": "Mensajes por página"
    },
    {
      "type": "textarea",
      "id": "message_product",
      "label": "t:whatsapp_button.settings.message_product.label",
      "info": "t:whatsapp_button.settings.message_product.info",
      "default": "Hola! Me interesa este producto: [product_name] - [product_url]"
    },
    {
      "type": "textarea",
      "id": "message_home",
      "label": "t:whatsapp_button.settings.message_home.label",
      "default": "Hola! Quiero más información sobre sus productos"
    },
    {
      "type": "textarea",
      "id": "message_collection",
      "label": "t:whatsapp_button.settings.message_collection.label",
      "info": "t:whatsapp_button.settings.message_collection.info",
      "default": "Hola! Estoy viendo la colección: [collection_name]"
    },
    {
      "type": "textarea",
      "id": "message_default",
      "label": "t:whatsapp_button.settings.message_default.label",
      "default": "Hola! Quiero más información"
    },
    {
      "type": "header",
      "content": "Posición"
    },
    {
      "type": "select",
      "id": "button_position",
      "label": "t:whatsapp_button.settings.button_position.label",
      "default": "bottom_right",
      "options": [
        { "value": "bottom_right", "label": "t:whatsapp_button.settings.button_position.options.bottom_right" },
        { "value": "bottom_left", "label": "t:whatsapp_button.settings.button_position.options.bottom_left" }
      ]
    },
    {
      "type": "range",
      "id": "button_margin",
      "label": "t:whatsapp_button.settings.button_margin.label",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_margin_y",
      "label": "t:whatsapp_button.settings.button_margin_y.label",
      "min": 0,
      "max": 300,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Apariencia del botón"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "t:whatsapp_button.settings.button_size.label",
      "min": 40,
      "max": 80,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "t:whatsapp_button.settings.button_color.label",
      "default": "#25D366"
    },
    {
      "type": "checkbox",
      "id": "pulse_animation",
      "label": "t:whatsapp_button.settings.pulse_animation.label",
      "default": true
    },
    {
      "type": "header",
      "content": "Tooltip (mensaje al lado)"
    },
    {
      "type": "text",
      "id": "tooltip_text",
      "label": "t:whatsapp_button.settings.tooltip_text.label",
      "default": "Comprar por wpp"
    },
    {
      "type": "color",
      "id": "tooltip_bg_color",
      "label": "t:whatsapp_button.settings.tooltip_bg_color.label",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tooltip_text_color",
      "label": "t:whatsapp_button.settings.tooltip_text_color.label",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Visibilidad"
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "t:whatsapp_button.settings.show_on_mobile.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "t:whatsapp_button.settings.show_on_desktop.label",
      "default": true
    }
  ]
}
{% endschema %}
